// Week 1 Prisma Schema for Modern Essentials
// Tables: users, products, orders, inventory_batches, webhook_events
// Week 4 Addition: subscriptions, subscription_events, ledger_entries

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core user identity - phone is primary login in India
model User {
  id        String   @id @default(cuid())
  phone     String   @unique // Primary login in India
  email     String?  @unique
  clerkId   String   @unique @map("clerk_id")
  tier      UserTier @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  orders       Order[]
  carts        Cart[]
  subscriptions Subscription[]
  ledgerEntries LedgerEntry[]

  @@map("users")
}

enum UserTier {
  FREE
  MEMBER
}

// Product catalog - eggs and future dairy
model Product {
  id         String      @id @default(cuid())
  sku        String      @unique // Stock keeping unit
  name       String
  category   Category
  price      Int         // Price in paise (Rs 100 = 10000)
  subPrice   Int         @map("sub_price") // Subscription price (discounted)
  isActive   Boolean     @default(true) @map("is_active")
  images     ProductImage[]
  description String?     // SEO and product description
  seoTitle   String?     @map("seo_title") // SEO meta title
  seoDesc     String?     @map("seo_desc") // SEO meta description
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  // Relations
  inventoryBatches InventoryBatch[]
  orders           OrderItem[]
  cartItems        CartItem[]
  subscriptionItems SubscriptionItem[]
  subscriptions     Subscription[]

  @@map("products")
}

enum Category {
  REGULAR_EGGS
  BROWN_EGGS
  HIGH_PROTEIN_EGGS
}

// Product images for Cloudflare R2 CDN
model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String   // Cloudflare R2 CDN URL
  alt       String?  // Alt text for accessibility
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

// FEFO inventory tracking - First Expired, First Out
// Critical for perishables - ORDER BY expires_at ASC on every pick
model InventoryBatch {
  id          String        @id @default(cuid())
  productId   String        @map("product_id")
  qty         Int           // Current quantity
  receivedAt  DateTime      @map("received_at")
  expiresAt   DateTime      @map("expires_at") // FEFO sort key
  locationId  String?       @map("location_id") // Warehouse bin location
  status      BatchStatus   @default(AVAILABLE)
  qcStatus    QCStatus      @default(PENDING) @map("qc_status")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@index([productId, expiresAt]) // FEFO pick index
  @@index([status, expiresAt])
  @@map("inventory_batches")
}

enum BatchStatus {
  AVAILABLE
  RESERVED
  DISPATCHED
  WASTAGE
}

enum QCStatus {
  PENDING
  PASS
  QUARANTINE
  REJECT
}

// Order tracking - both one-time and subscription renewals
model Order {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  subscriptionId String?     @map("subscription_id") // Null for one-time orders
  razorpayOrderId String?    @unique @map("razorpay_order_id")
  status         OrderStatus @default(PENDING)
  type           OrderType
  total          Int         // Total in paise
  
  // Delivery Address
  addressLine1   String?     @map("address_line_1")
  city           String?
  state          String?
  postalCode     String?     @map("postal_code")
  
  placedAt       DateTime    @default(now()) @map("placed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  items        OrderItem[]

  @@index([userId, placedAt])
  @@index([status, placedAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PAYMENT_FAILED
  PICKED
  PACKED
  DISPATCHED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  ONE_TIME
  SUBSCRIPTION_RENEWAL
}

// Order line items
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  qty       Int
  price     Int    // Price at time of order (in paise)
  total     Int    // price * qty

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

// Week 4: Subscription System
model Subscription {
  id                String              @id @default(cuid())
  userId             String
  productId          String
  razorpaySubscriptionId String?        @unique @map("razorpay_subscription_id")
  quantity           Int                  // eggs per delivery
  frequency          SubscriptionFrequency  @default(WEEKLY)
  status             SubscriptionStatus   @default(ACTIVE)
  nextBillingAt      DateTime             @default(now()) // when next payment/order should be generated
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  items      SubscriptionItem[]
  events      SubscriptionEvent[]
  orders     Order[]

  @@index([userId, status])
  @@map("subscriptions")
}

enum SubscriptionFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  RENEWAL_DUE
  DUNNING
  CANCELLED
  EXPIRED
}

model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId  String
  productId      String
  quantity       Int
  price          Int       // subscription price in paise
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("subscription_items")
}

model SubscriptionEvent {
  id             String                @id @default(cuid())
  subscriptionId  String
  eventType      SubscriptionEventType
  description    String?
  metadata       Json?                 // additional event data
  createdAt      DateTime              @default(now())

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_events")
}

enum SubscriptionEventType {
  CREATED
  ACTIVATED
  UPDATED
  PAUSED
  RESUMED
  CANCELLED
  EXPIRED
  PAYMENT_FAILED
  RENEWED
}

// Week 4: Rewards Ledger System
model LedgerEntry {
  id        String   @id @default(cuid())
  userId     String
  type       LedgerEntryType
  points     Int       // can be positive (earn) or negative (spend)
  description String
  metadata   Json?     // additional context
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

enum LedgerEntryType {
  EARN
  SPEND
}

// Webhook event log - idempotency key: (provider, event_id)
// Every handler MUST check this table before processing
model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String    // e.g., 'razorpay', 'interakt', 'shadowfax'
  eventId     String    @map("event_id") // Provider's event ID
  eventType    String    @map("event_type") // e.g., 'payment.captured'
  processed    Boolean   @default(false)
  data         Json     // full webhook payload
  processedAt  DateTime? @map("processed_at") // Null = not yet processed
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId]) // Idempotency constraint
  @@index([provider, eventType])
  @@map("webhook_events")
}

// Shopping cart system for user orders
model Cart {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([userId]) // One cart per user
  @@map("carts")
}

// Individual items in a user's cart
model CartItem {
  id            String   @id @default(cuid())
  cartId        String   @map("cart_id")
  productId     String   @map("product_id")
  quantity      Int
  priceSnapshot Int      @map("price_snapshot") // Price at time of adding (in paise)
  isSubscription Boolean  @default(false) @map("is_subscription")
  frequency     SubscriptionFrequency?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, isSubscription]) // Allow same product as both one-time and sub
  @@map("cart_items")
}
