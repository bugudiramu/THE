# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modern_essentials"

# Redis connection
REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV="development"

# CORS origins
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# Clerk (auth) - Get from Clerk dashboard
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Razorpay - Get from Razorpay dashboard
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Resend (email) - Get from Resend dashboard
RESEND_API_KEY=""

# Interakt (WhatsApp) - Get from Interakt dashboard
